{
  "name": "sailingsimulator",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "A focused browser sailing simulator that teaches wind awareness, trim, luffing, and tacking on a vast lake.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "sailing",
    "simulator",
    "three.js",
    "education",
    "game"
  ],
  "license": "MIT",
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
